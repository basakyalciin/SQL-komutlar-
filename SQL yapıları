7. Program İzlenebilirlik Araçları — Hata ve Loglama

SQL Server:
- PRINT — Ekrana mesaj yazdırır
- RAISERROR — Hata mesajı oluşturur
- TRY...CATCH — Hata yakalama

Örnek:
BEGIN TRY
    INSERT INTO musteriler (ad, yas) VALUES ('Ali', 25);
END TRY
BEGIN CATCH
    PRINT 'Hata oluştu: ' + ERROR_MESSAGE();
END CATCH;

MySQL:
- SELECT 'mesaj' — Basit mesaj
- SIGNAL — Hata fırlatma (MySQL 5.5+)

Örnek:
DELIMITER //
CREATE PROCEDURE HataDeneme()
BEGIN
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
        SELECT 'Hata oluştu!' AS Hata;
    INSERT INTO urunler (ad, fiyat) VALUES ('Yeni Ürün', -10);
END //
DELIMITER ;

PostgreSQL:
- RAISE NOTICE — Bilgi mesajı
- RAISE EXCEPTION — Hata fırlatma

Örnek:
DO $$
BEGIN
    RAISE NOTICE 'İşlem başlıyor...';
    INSERT INTO calisanlar (ad, maas) VALUES ('Veli', -1000);
EXCEPTION
    WHEN others THEN
        RAISE EXCEPTION 'Hata: %', SQLERRM;
END $$;

Oracle:
- DBMS_OUTPUT.PUT_LINE — Mesaj yazdırır
- RAISE_APPLICATION_ERROR — Hata fırlatma

Örnek:
BEGIN
    DBMS_OUTPUT.PUT_LINE('İşlem başlıyor...');
    INSERT INTO siparisler (musteri_id, tarih) VALUES (999, SYSDATE);
EXCEPTION
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Hata: ' || SQLERRM);
END;


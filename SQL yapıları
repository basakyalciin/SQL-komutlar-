8. Yığın İşlemi (Transaction) — COMMIT ve ROLLBACK

SQL Server / MySQL / PostgreSQL / Oracle:
BEGIN TRANSACTION — İşlem başlar
COMMIT — Değişiklikleri kalıcı yapar
ROLLBACK — Değişiklikleri geri alır

Örnek (SQL Server):
BEGIN TRANSACTION;
UPDATE hesaplar SET bakiye = bakiye - 100 WHERE hesap_no = 1;
UPDATE hesaplar SET bakiye = bakiye + 100 WHERE hesap_no = 2;
COMMIT;

Hata durumunda:
BEGIN TRANSACTION;
UPDATE hesaplar SET bakiye = bakiye - 100 WHERE hesap_no = 1;
UPDATE hesaplar SET bakiye = bakiye + 100 WHERE hesap_no = 2;
IF @@ERROR <> 0
    ROLLBACK;
ELSE
    COMMIT;

MySQL:
START TRANSACTION;
UPDATE hesaplar SET bakiye = bakiye - 100 WHERE hesap_no = 1;
UPDATE hesaplar SET bakiye = bakiye + 100 WHERE hesap_no = 2;
COMMIT;

PostgreSQL:
BEGIN;
UPDATE hesaplar SET bakiye = bakiye - 100 WHERE hesap_no = 1;
UPDATE hesaplar SET bakiye = bakiye + 100 WHERE hesap_no = 2;
COMMIT;

Oracle:
BEGIN
    UPDATE hesaplar SET bakiye = bakiye - 100 WHERE hesap_no = 1;
    UPDATE hesaplar SET bakiye = bakiye + 100 WHERE hesap_no = 2;
    COMMIT;
EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
END;


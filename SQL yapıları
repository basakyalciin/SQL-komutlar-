5. Dinamik SQL — Çalışma Zamanında Oluşturulan Sorgular

SQL Server:
EXEC sp_executesql veya EXEC('sorgu')

Örnek:
DECLARE @tablo NVARCHAR(50) = 'musteriler';
DECLARE @sorgu NVARCHAR(MAX);
SET @sorgu = 'SELECT * FROM ' + @tablo;
EXEC sp_executesql @sorgu;

Parametreli:
DECLARE @sorgu NVARCHAR(MAX) = 'SELECT * FROM musteriler WHERE yas > @yas';
EXEC sp_executesql @sorgu, N'@yas INT', @yas = 30;

MySQL:
PREPARE ve EXECUTE ile

Örnek:
SET @tablo = 'urunler';
SET @sorgu = CONCAT('SELECT * FROM ', @tablo);
PREPARE stmt FROM @sorgu;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;

PostgreSQL:
EXECUTE komutu ile

Örnek:
DO $$
DECLARE
    tablo TEXT := 'calisanlar';
    sorgu TEXT;
BEGIN
    sorgu := 'SELECT * FROM ' || tablo;
    EXECUTE sorgu;
END $$;

Oracle:
EXECUTE IMMEDIATE ile

Örnek:
DECLARE
    tablo VARCHAR2(50) := 'siparisler';
    sorgu VARCHAR2(100);
BEGIN
    sorgu := 'SELECT COUNT(*) FROM ' || tablo;
    EXECUTE IMMEDIATE sorgu;
END;


6. İmleç (Cursor) — Satır Satır Veri İşleme

SQL Server:
DECLARE cursor_name CURSOR FOR sorgu;
OPEN cursor_name;
FETCH NEXT FROM cursor_name INTO değişkenler;
WHILE @@FETCH_STATUS = 0
BEGIN
    ... işlemler ...
    FETCH NEXT FROM cursor_name INTO değişkenler;
END
CLOSE cursor_name;
DEALLOCATE cursor_name;

Örnek:
DECLARE @ad NVARCHAR(50), @yas INT;
DECLARE musteriler_cursor CURSOR FOR
    SELECT ad, yas FROM musteriler WHERE yas > 25;

OPEN musteriler_cursor;
FETCH NEXT FROM musteriler_cursor INTO @ad, @yas;

WHILE @@FETCH_STATUS = 0
BEGIN
    PRINT 'Ad: ' + @ad + ', Yaş: ' + CAST(@yas AS VARCHAR);
    FETCH NEXT FROM musteriler_cursor INTO @ad, @yas;
END

CLOSE musteriler_cursor;
DEALLOCATE musteriler_cursor;

MySQL:
DECLARE cursor_name CURSOR FOR sorgu;
OPEN cursor_name;
FETCH cursor_name INTO değişkenler;
WHILE NOT done DO
    ... işlemler ...
    FETCH cursor_name INTO değişkenler;
END WHILE;
CLOSE cursor_name;

Örnek:
DELIMITER //
CREATE PROCEDURE Islem()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE ad VARCHAR(50);
    DECLARE yas INT;
    DECLARE musteriler_cursor CURSOR FOR SELECT ad, yas FROM musteriler WHERE yas > 25;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    OPEN musteriler_cursor;
    read_loop: LOOP
        FETCH musteriler_cursor INTO ad, yas;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT CONCAT('Ad: ', ad, ', Yaş: ', yas);
    END LOOP;
    CLOSE musteriler_cursor;
END //
DELIMITER ;

PostgreSQL:
FOR record IN sorgu LOOP ... END LOOP; (önerilen yöntem)

Örnek:
DO $$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN SELECT ad, yas FROM calisanlar WHERE yas > 30 LOOP
        RAISE NOTICE 'Ad: %, Yaş: %', rec.ad, rec.yas;
    END LOOP;
END $$;

Oracle:
CURSOR ile

Örnek:
DECLARE
    CURSOR calisan_cursor IS SELECT ad, maas FROM calisanlar WHERE maas > 4000;
    calisan_rec calisan_cursor%ROWTYPE;
BEGIN
    OPEN calisan_cursor;
    LOOP
        FETCH calisan_cursor INTO calisan_rec;
        EXIT WHEN calisan_cursor%NOTFOUND;
        DBMS_OUTPUT.PUT_LINE('Ad: ' || calisan_rec.ad || ', Maaş: ' || calisan_rec.maas);
    END LOOP;
    CLOSE calisan_cursor;
END;


9. Veri Değişikliklerinin Kaydedilmesi — Audit ve Trigger

SQL Server:
AFTER INSERT, UPDATE, DELETE trigger ile

Örnek:
CREATE TRIGGER trg_musteri_log
ON musteriler
AFTER INSERT, UPDATE, DELETE
AS
BEGIN
    INSERT INTO musterilog (islem, tarih, kullanici)
    VALUES ('Değişiklik', GETDATE(), SYSTEM_USER);
END;

MySQL:
AFTER INSERT, UPDATE, DELETE trigger

Örnek:
DELIMITER //
CREATE TRIGGER trg_urun_log
AFTER UPDATE ON urunler
FOR EACH ROW
BEGIN
    INSERT INTO urunlog (urun_id, eski_fiyat, yeni_fiyat, tarih)
    VALUES (OLD.id, OLD.fiyat, NEW.fiyat, NOW());
END //
DELIMITER ;

PostgreSQL:
AFTER INSERT, UPDATE, DELETE trigger

Örnek:
CREATE OR REPLACE FUNCTION log_urun()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO urunlog (urun_id, eski_fiyat, yeni_fiyat, tarih)
    VALUES (OLD.id, OLD.fiyat, NEW.fiyat, NOW());
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_urun_log
AFTER UPDATE ON urunler
FOR EACH ROW
EXECUTE FUNCTION log_urun();

Oracle:
AFTER INSERT, UPDATE, DELETE trigger

Örnek:
CREATE OR REPLACE TRIGGER trg_siparis_log
AFTER INSERT ON siparisler
FOR EACH ROW
BEGIN
    INSERT INTO siparislog (siparis_id, tarih, kullanici)
    VALUES (:NEW.id, SYSDATE, USER);
END;


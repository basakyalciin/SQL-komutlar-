10. Hata Denetimi — TRY...CATCH, Exception Handling

SQL Server:
BEGIN TRY ... END TRY
BEGIN CATCH ... END CATCH

Örnek:
BEGIN TRY
    INSERT INTO musteriler (ad, yas) VALUES ('Ali', -5);
END TRY
BEGIN CATCH
    PRINT 'Hata: ' + ERROR_MESSAGE();
    PRINT 'Satır: ' + CAST(ERROR_LINE() AS VARCHAR);
END CATCH;

MySQL:
DECLARE CONTINUE HANDLER FOR SQLEXCEPTION

Örnek:
DELIMITER //
CREATE PROCEDURE HataYakala()
BEGIN
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
        SELECT 'Hata oluştu!' AS Hata;
    INSERT INTO urunler (ad, fiyat) VALUES ('Yeni Ürün', -10);
END //
DELIMITER ;

PostgreSQL:
EXCEPTION WHEN others THEN

Örnek:
DO $$
BEGIN
    INSERT INTO calisanlar (ad, maas) VALUES ('Veli', -1000);
EXCEPTION
    WHEN others THEN
        RAISE EXCEPTION 'Hata: %', SQLERRM;
END $$;

Oracle:
EXCEPTION WHEN OTHERS THEN

Örnek:
BEGIN
    INSERT INTO siparisler (musteri_id, tarih) VALUES (999, SYSDATE);
EXCEPTION
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Hata: ' || SQLERRM);
END;

